# Copy this file to .env.local and fill in your Supabase project values.
# Both vars are also required in your Vercel project settings.
# RLS limits the anon key to the qa_flags + qa_comments tables only.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: Cloudflare Turnstile site key. If set, the app fetches a captcha
# token before every sign-up / sign-in / password-reset submit and forwards
# it to Supabase. Also enable "CAPTCHA protection" in Supabase Auth settings
# and configure the matching secret key there so the server enforces it.
# Leave unset locally — auth flows still work without a captcha.
VITE_TURNSTILE_SITE_KEY=
